{
  "name": "crypto-terminal",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://anandkchandran.github.io/cryptoedge",
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "server": "node server.js",
    "predeploy": "DISABLE_ESLINT_PLUGIN=true REACT_APP_API_URL=$RAILWAY_URL npm run build",
    "deploy": "bash deploy.sh"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "overrides": {
    "babel-loader": {
      "schema-utils": "2.7.1"
    },
    "eslint-webpack-plugin": {
      "ajv": "6.12.6",
      "ajv-keywords": "3.5.2"
    },
    "fork-ts-checker-webpack-plugin": {
      "ajv": "6.12.6"
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=10.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
